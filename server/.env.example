PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/fleetflow
JWT_SECRET=fleetflow_super_secret_key_change_in_production
JWT_EXPIRE=7d
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# OpenRouteService - Maps & Routing
# Get API key from https://openrouteservice.org/register/
OPENROUTE_API_KEY=replace_with_your_openrouteservice_api_key

# SendGrid - Email Service
# Get API key from https://sendgrid.com/
SENDGRID_API_KEY=replace_with_your_sendgrid_api_key
EMAIL_FROM=noreply@fleetflowail.com